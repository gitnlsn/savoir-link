# Copy to .env.test to run the Pagar.me sandbox integration tests (`npm test`).
# Without a real sk_test_* key, the sandbox tests self-skip.

AUTH_SECRET="test-secret"
AUTH_GOOGLE_ID="test-google-id"
AUTH_GOOGLE_SECRET="test-google-secret"
APP_URL="http://localhost:3000"
DATABASE_URL="postgresql://postgres@localhost:5432/savoir-link"

# Your Pagar.me SANDBOX secret key (routes to https://sdx-api.pagar.me).
PAGARME_API_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

CURRENCY="BRL"
CURRENCY_LOCALE="pt-BR"
