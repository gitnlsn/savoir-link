# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth (providers log in with Google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App
APP_URL="http://localhost:3000"

# Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/savoir-link"

# Pagar.me (sk_test_* for sandbox, sk_* for production)
PAGARME_API_KEY="sk_test_xxx"
PAGARME_WEBHOOK_URL="http://localhost:3000/api/webhooks/pagarme"
WEBHOOK_AUTH_USERNAME=""
WEBHOOK_AUTH_PASSWORD=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="no-reply@savoirlink.com"
RESEND_FROM_NAME="Savoir Link"
SUPPORT_EMAIL="suporte@savoirlink.com"

# Currency
CURRENCY="BRL"
CURRENCY_LOCALE="pt-BR"

# Google Maps (Places API — server-side)
GOOGLE_MAPS_API_KEY=""

# Cron / revalidation
CRON_SECRET=""
REVALIDATION_API_KEY=""

# Client
NEXT_PUBLIC_ENABLE_GOOGLE_PLACES="false"
NEXT_PUBLIC_GTM_ID=""
