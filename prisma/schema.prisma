// Savoir Link — leads marketplace schema.
// Customers pay to publish orders; providers buy credits and spend them to unlock contacts.
// All money flows to the platform (no payouts to providers).

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (NextAuth / Auth.js — Google provider, database sessions)
// ─────────────────────────────────────────────────────────────────────────────

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    createdAt     DateTime  @default(now())

    accounts Account[]
    sessions Session[]

    // Provider-side relations
    wallet   CreditWallet?
    unlocks  ContactUnlock[]
    payments Payment[]
}

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    session_state            String?
    id_token                 String?
    refresh_token_expires_in Int?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Taxonomy & geography
// ─────────────────────────────────────────────────────────────────────────────

model Category {
    id       String  @id @default(cuid())
    slug     String  @unique
    name     String
    icon     String?
    parentId String?
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children Category[] @relation("CategoryHierarchy")

    orders Order[] @relation("OrderCategories")

    @@index([parentId])
}

model Location {
    id        String  @id @default(cuid())
    city      String
    state     String // UF (e.g. "SP")
    slug      String  @unique // e.g. "sao-paulo-sp"
    placeId   String? @unique
    latitude  Float?
    longitude Float?

    orders Order[]

    @@index([state])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders (customer-posted service requests)
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
    PENDING_PAYMENT
    ACTIVE
    EXPIRED
    CLOSED
}

model Order {
    id       String @id @default(cuid())
    // Public, SEO-friendly identifier used in URLs (not the internal id).
    publicId String @unique
    // Anonymous-management token emailed to the customer.
    manageToken String @unique

    status OrderStatus @default(PENDING_PAYMENT)

    title       String
    description String
    budget      Decimal @db.Decimal(10, 2)

    categories Category[] @relation("OrderCategories")
    locationId String
    location   Location @relation(fields: [locationId], references: [id])

    // Contact details — NEVER exposed by public/browse queries; only via ContactUnlock.
    contactName     String
    contactPhone    String
    contactWhatsapp String?
    contactEmail    String

    // Duration / lifecycle
    durationDays Int
    publishedAt  DateTime?
    expiresAt    DateTime?
    unlockCount  Int       @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    payments Payment[]
    unlocks  ContactUnlock[]

    @@index([status, expiresAt])
    @@index([locationId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Provider credit wallet
// ─────────────────────────────────────────────────────────────────────────────

model CreditWallet {
    id      String @id @default(cuid())
    userId  String @unique
    balance Int    @default(0)
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    transactions CreditTransaction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum CreditTransactionType {
    TOPUP
    UNLOCK
}

model CreditTransaction {
    id       String                @id @default(cuid())
    walletId String
    wallet   CreditWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
    type     CreditTransactionType
    // Signed change to the balance (+ for TOPUP, - for UNLOCK).
    delta    Int
    // Optional back-references for auditing.
    paymentId       String?
    contactUnlockId String? @unique

    createdAt DateTime @default(now())

    // Idempotency guard: a given payment can only produce one TOPUP credit, even under
    // concurrent/duplicate webhook deliveries. (UNLOCK rows have a null paymentId, and Postgres
    // treats NULLs as distinct, so this does not constrain unlock ledger entries.)
    @@unique([paymentId, type])
    @@index([walletId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Contact unlocks (a provider paid credits to reveal an order's contact)
// ─────────────────────────────────────────────────────────────────────────────

model ContactUnlock {
    id           String   @id @default(cuid())
    providerId   String
    provider     User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
    orderId      String
    order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
    creditsSpent Int
    createdAt    DateTime @default(now())

    // A provider can only unlock a given order once.
    @@unique([providerId, orderId])
    @@index([providerId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments (unified — Pagar.me checkout for both order publication & credit top-ups)
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentType {
    ORDER_PUBLICATION
    CREDIT_TOPUP
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    CANCELLED
}

model Payment {
    id     String        @id @default(cuid())
    type   PaymentType
    status PaymentStatus @default(PENDING)
    // Amount charged, in the major currency unit (BRL).
    amount Decimal       @db.Decimal(10, 2)

    // Pagar.me references
    pagarmeOrderId String? @unique
    checkoutUrl    String?

    // Who/what this payment is for
    payerEmail String
    // For ORDER_PUBLICATION
    orderId String?
    order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
    // For CREDIT_TOPUP
    userId         String?
    user           User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
    creditQuantity Int?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    paidAt    DateTime?

    @@index([status, type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Webhook audit / idempotency
// ─────────────────────────────────────────────────────────────────────────────

model WebhookEvent {
    id             String    @id @default(cuid())
    pagarmeEventId String    @unique
    type           String
    payload        Json
    processedAt    DateTime?
    createdAt      DateTime  @default(now())

    @@index([type])
}
